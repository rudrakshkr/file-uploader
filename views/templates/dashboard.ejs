<div id="uploadModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Enter the File</h2>
            <span class="close-btn" style="cursor:pointer;">&times;</span>
        </div>
        <form class="modal-body" action="/upload" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="folderId" value="<%= currentFolderId || '' %>">
            <div class="custom-file-wrapper">
                <label for="fileInput" class="file-label">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                    <span>Choose a file...</span>
                </label>
                <input type="file" id="fileInput" name="fileInput" required>
                <p id="fileNameDisplay">No file selected</p>
            </div>
            <button type="submit" class="submit-upload">Upload to Cloud</button>
        </form>
    </div>
</div>

<div id="folderModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Enter the Folder Name</h2>
            <span class="close-btn" style="cursor:pointer;">&times;</span>
        </div>
        <form class="modal-body" action="/add-folder" method="POST">
            <input type="text" id="folderInput" name="folderInput" required>
            <button type="submit" class="submit-upload">Add Folder</button>
        </form>
    </div>
</div>
<main class="dashboard">
    <section class="sidebar">
        <div class="app-logo">
            <img src="/assets/icons/cloud-icon.svg" alt="logo">
            <p>CloudVault</p>
        </div>

        <div class="upload-section">
            <button id="openUploadBtn">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M17 17H17.01M15.6 14H18C18.9319 14 19.3978 14 19.7654 14.1522C20.2554 14.3552 20.6448 14.7446 20.8478 15.2346C21 15.6022 21 16.0681 21 17C21 17.9319 21 18.3978 20.8478 18.7654C20.6448 19.2554 20.2554 19.6448 19.7654 19.8478C19.3978 20 18.9319 20 18 20H6C5.06812 20 4.60218 20 4.23463 19.8478C3.74458 19.6448 3.35523 19.2554 3.15224 18.7654C3 18.3978 3 17.9319 3 17C3 16.0681 3 15.6022 3.15224 15.2346C3.35523 14.7446 3.74458 14.3552 4.23463 14.1522C4.60218 14 5.06812 14 6 14H8.4M12 15V4M12 4L15 7M12 4L9 7" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
                <p>Upload File</p>
            </button>
            <button id="openFolderBtn">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M9 13H15M12 10V16M12.0627 6.06274L11.9373 5.93726C11.5914 5.59135 11.4184 5.4184 11.2166 5.29472C11.0376 5.18506 10.8425 5.10425 10.6385 5.05526C10.4083 5 10.1637 5 9.67452 5H6.2C5.0799 5 4.51984 5 4.09202 5.21799C3.71569 5.40973 3.40973 5.71569 3.21799 6.09202C3 6.51984 3 7.07989 3 8.2V15.8C3 16.9201 3 17.4802 3.21799 17.908C3.40973 18.2843 3.71569 18.5903 4.09202 18.782C4.51984 19 5.07989 19 6.2 19H17.8C18.9201 19 19.4802 19 19.908 18.782C20.2843 18.5903 20.5903 18.2843 20.782 17.908C21 17.4802 21 16.9201 21 15.8V10.2C21 9.0799 21 8.51984 20.782 8.09202C20.5903 7.71569 20.2843 7.40973 19.908 7.21799C19.4802 7 18.9201 7 17.8 7H14.3255C13.8363 7 13.5917 7 13.3615 6.94474C13.1575 6.89575 12.9624 6.81494 12.7834 6.70528C12.5816 6.5816 12.4086 6.40865 12.0627 6.06274Z" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
                <p>New Folder</p>
            </button>
        </div>

        <div class="folders">
            <div class="folder-item root-folder" style="display: flex; justify-content: space-between; align-items: center;">
                <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit;">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" height="24" width="24">
                        <line x1="22" y1="12" x2="2" y2="12"></line> 
                        <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"></path> 
                        <line x1="6" y1="16" x2="6.01" y2="16"></line> 
                        <line x1="10" y1="16" x2="10.01" y2="16"></line>
                    </svg>
                    <p style="margin: 0; font-weight: bold;">My Drive</p>
                </a>
            </div>

            <hr style="border: 0; border-top: 1px solid #eee; margin: 15px 0;">

            <div class="custom-folders-list">
                <% if(typeof folders !== 'undefined' && folders.length > 0) { %>
                    <% folders.forEach(folder => { %>
                        <div class="folder-item" style="display: flex; justify-content: space-between; align-items: center;">
                            
                            <a href="/folder/<%= folder.id %>" style="display: flex; align-items: center; gap: 10px; text-decoration: none; color: inherit;">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" height="24" width="24">
                                    <line x1="22" y1="12" x2="2" y2="12"></line> 
                                    <path d="M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z"></path> 
                                    <line x1="6" y1="16" x2="6.01" y2="16"></line> 
                                    <line x1="10" y1="16" x2="10.01" y2="16"></line>
                                </svg>
                                <p style="margin: 0;"><%= folder.name %></p>
                            </a>

                            <div class="action-buttons" style="display: flex; gap: 8px;">
                                <form method="POST" action="/folder/<%= folder.id %>/delete" style="margin: 0;">
                                    <button type="submit" style="background: none; border: none; cursor: pointer; padding: 0;">
                                        <img src="/assets/icons/delete-icon.png" alt="delete-item" height="23">
                                    </button>
                                </form>
                                <a href="/folder/<%= folder.id %>/edit" style="cursor: pointer;">
                                    <img src="/assets/icons/edit-icon.png" alt="edit-icon" height="23">
                                </a>
                            </div>

                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>
        
    </section>
    <section class="files-section">
        <div class="user-info">
            <p><%= user.fullname %></p>
            <img src="/assets/my-photo.jpeg" alt="my-photu">
            <a class="logout-btn" href="/log-out">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M14 20H6C4.89543 20 4 19.1046 4 18L4 6C4 4.89543 4.89543 4 6 4H14M10 12H21M21 12L18 15M21 12L18 9" stroke="#565D6DFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
                <p>Log Out</p> 
            </a>
        </div>

        <hr>

        <div class="header-info">
            <div class="destination">
                <h4><span><%= currentFolder %> > </span>My Files</h4>
            </div>
            <div class="file-header">
                <p>All Files</p>
                <p>Syncing: Up to date</p>
            </div>
        </div>
        <div class="category-table">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Size</th>
                        <th>Upload Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(typeof files !== 'undefined' && files.length > 0) { %>
                        <% files.forEach(file => { %>
                            <% if(file.userId === user.id) { %>
                                <tr>
                                    <td>
                                        <%= file.originalName %>
                                    </td>
                                    <td><%= (file.size / 1024).toFixed(1) %> KB</td>
                                    <td><%= file.displayDate %></td>
                                    <td>
                                        <div class="action-buttons">
                                            <form method="POST" action="/file/<%= file.id %>/delete">
                                                <button type="submit">
                                                    <img src="/assets/icons/delete-icon.png" alt="delete-item" height="25">
                                                </button>
                                            </form>
                                            <a>
                                                <img src="/assets/icons/edit-icon.png" alt="edit-icon" height="25">
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        <% }) %>
                    <% } %>
                    <!-- If folder and files empty -->
                    <% if((typeof files === 'undefined' || files.length === 0) && (typeof folders === 'undefined' || folders.length === 0)) { %>
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 40px; color: #666;">
                                This folder is empty. Upload a file or create a folder to get started!
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </section>
</main>   

<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Upload Modal
        const uploadModal = document.getElementById("uploadModal");
        const btnUpload = document.getElementById("openUploadBtn");

        // Folder Modal
        const folderModal = document.getElementById("folderModal");
        const btnFolder = document.getElementById("openFolderBtn");

        // Close buttton
        const closeBtn = document.querySelector(".close-btn");

        // Open modal
        btnUpload.onclick = function() {
            uploadModal.style.display = "block";
        }

        btnFolder.onclick = function() {
            folderModal.style.display = "block";
        }

        // Close modal && Close modal by clicking outside the box
        window.onclick = function(event) {
            if (event.target.classList.contains("close-btn")) {
                uploadModal.style.display = "none";
                folderModal.style.display = "none";
            }

            if (event.target === uploadModal) {
                uploadModal.style.display = "none";
            }
            else if(event.target === folderModal) {
                folderModal.style.display = "none";
            }
        }

        // To show filename
        const fileInput = document.getElementById('fileInput');
        const fileNameDisplay = document.getElementById('fileNameDisplay');

        fileInput.addEventListener('change', (e) => {
            const fileName = e.target.files[0]?.name || "No file selected";
            fileNameDisplay.textContent = fileName;
        });
    });
</script>